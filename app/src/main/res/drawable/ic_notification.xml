<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_notification.xml - Notification Icon (Vector Drawable)
    This icon appears in the status bar when a notification is received.

    NOTIFICATION ICON REQUIREMENTS:
    1. Must be a simple monochrome (single color) shape
    2. Android uses ONLY the ALPHA channel (transparency) to render it
    3. The color set here doesn't matter much - Android uses colorPrimary
    4. Should be simple enough to be recognizable at small sizes
    5. Recommended size: 24dp x 24dp

    This is a simple bell icon path drawn with SVG-style vector paths.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Bell body: The main body of the notification bell.
        This path draws a bell shape using SVG path commands:
        M = MoveTo, C = CurveTo, L = LineTo, Z = ClosePath
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,22c1.1,0 2,-0.9 2,-2h-4c0,1.1 0.9,2 2,2zm6,-6v-5c0,-3.07 -1.64,-5.64 -4.5,-6.32L13.5,4c0,-0.83 -0.67,-1.5 -1.5,-1.5s-1.5,0.67 -1.5,1.5v0.68C7.63,5.36 6,7.92 6,11v5l-2,2v1h16v-1l-2,-2z" />

</vector>
