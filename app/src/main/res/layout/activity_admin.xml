<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_admin.xml - Admin Panel Layout
    Features:
    - Toolbar with back navigation
    - Scrollable form to add new events
    - Input fields for title, description, date/time, location
    - Category spinner (dropdown)
    - Add Event button
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar with title "Admin Panel" -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <!-- Scrollable content to handle small screens / keyboard appearance -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== INFO BANNER ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#E8F5E9">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️"
                        android:textSize="20sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Add new campus events below. Students will see them in real-time. Send FCM notifications from Firebase Console to alert students."
                        android:textSize="12sp"
                        android:textColor="#2E7D32" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== FORM CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- SECTION TITLE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Event Details"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="20dp" />

                    <!-- EVENT TITLE FIELD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Event Title *"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etEventTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g., Mathematics Final Exam"
                        android:inputType="textCapSentences"
                        android:background="@drawable/input_background"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="2"
                        android:imeOptions="actionNext" />

                    <!-- CATEGORY FIELD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category *"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="4dp" />

                    <!--
                        Spinner = Dropdown selector
                        The items are set programmatically in AdminActivity.java
                    -->
                    <Spinner
                        android:id="@+id/spinnerCategory"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_background"
                        android:padding="4dp"
                        android:layout_marginBottom="16dp" />

                    <!-- DATE AND TIME FIELD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date &amp; Time *"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etEventDateTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g., 2024-03-15 at 10:00 AM"
                        android:inputType="textCapSentences"
                        android:background="@drawable/input_background"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="1"
                        android:imeOptions="actionNext" />

                    <!-- LOCATION FIELD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location *"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etEventLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g., Auditorium Hall A, Room 301"
                        android:inputType="textCapSentences"
                        android:background="@drawable/input_background"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="1"
                        android:imeOptions="actionNext" />

                    <!-- DESCRIPTION FIELD -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description *"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/etEventDescription"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:hint="Describe the event in detail..."
                        android:inputType="textMultiLine|textCapSentences"
                        android:background="@drawable/input_background"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:gravity="top"
                        android:layout_marginBottom="20dp"
                        android:scrollbars="vertical" />

                    <!-- PROGRESS BAR - shown during Firebase save -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <!-- ADD EVENT BUTTON -->
                    <Button
                        android:id="@+id/btnAddEvent"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="ADD EVENT"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/colorPrimary"
                        android:textColor="@android:color/white" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
