<?xml version="1.0" encoding="utf-8"?>
<!--
    input_background.xml - Input Field Background
    Applied to EditText fields for a consistent, clean appearance.
    Creates a white rectangle with a subtle grey border and rounded corners.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- White fill for readability -->
    <solid android:color="#FAFAFA" />

    <!-- Subtle grey border -->
    <stroke
        android:color="#BDBDBD"
        android:width="1dp" />

    <!-- Slightly rounded corners for a modern look -->
    <corners android:radius="8dp" />

</shape>
